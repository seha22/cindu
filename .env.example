# Supabase Postgres
# Backend Express ini paling aman memakai Session pooler jika environment Anda IPv4-only.
# Jika hosting mendukung IPv6, Anda bisa mengganti ke direct connection dari dashboard Supabase.
# Project ref aktif: tcqqpqbrrcbbrvhqbnsz
DATABASE_URL=postgresql://postgres.tcqqpqbrrcbbrvhqbnsz:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# App
PORT=5000
SESSION_SECRET=replace-with-a-long-random-secret
ENABLE_SEED=true

# Midtrans
MIDTRANS_IS_PRODUCTION=false
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxx
